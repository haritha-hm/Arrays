import java.util.*;
class Main {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int arr[]=new int[n];
        for(int i=0;i<n;i++){
            arr[i]=sc.nextInt();
        }
        int suffix[]=new int[n];
        suffix[n-1]=arr[n-1];
        for(int i=n-2;i>=0;i--){
           suffix[i]=Math.max(suffix[i+1],arr[i]);
        }
        for(int i:suffix){
            System.out.print(i+" ");
        }
    }
}
