import java.util.*;
class Main {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int arr[]=new int[n];
        for(int i=0;i<n;i++){
            arr[i]=sc.nextInt();
        }
        int prefix[0]=arr[0];
        for(int i=1;i<n;i++){
           prefix[i]=Math.max(prefix[i-1],arr[i]);
        }
        for(int i:n){
            System.out.print(i+" ");
        }
    }
}
